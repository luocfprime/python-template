name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  quality:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - name: Set up uv
        uses: astral-sh/setup-uv@v6
        with:
          python-version: 3.13
      - name: Install package
        run: uv sync --frozen
      - name: Run linters
        run: uv run task lint

  test:
    runs-on: {% raw %}${{ matrix.os }}{% endraw %}
    strategy:
      fail-fast: false
      matrix:
        os: [ubuntu-latest, macos-latest, windows-latest]
        python-version: ["3.10", "3.11", "3.12", "3.13"]
    steps:
      - uses: actions/checkout@v6
      - name: Set up uv
        uses: astral-sh/setup-uv@v6
        with:
          python-version: {% raw %}${{ matrix.python-version }}{% endraw %}
      - name: Install package
        run: uv sync --frozen --python {% raw %}${{ matrix.python-version }}{% endraw %}
      - name: Run tests
        run: uv run pytest --cov={{project_name}} --cov-report=xml --cov-report=term
      {% if codecov -%}
      - name: Upload coverage to Codecov
        if: matrix.os == 'ubuntu-latest' && matrix.python-version == '3.11'
        uses: codecov/codecov-action@v4
        with:
          files: ./coverage.xml
          fail_ci_if_error: true
          token: {% raw %}${{ secrets.CODECOV_TOKEN }}{% endraw %}
      {% endif -%}

  release:
    needs: [quality, test]
    runs-on: ubuntu-latest
    if: github.ref == 'refs/heads/main' && !contains(github.event.head_commit.message, 'cd skip')
    steps:
      - uses: actions/checkout@v6
      - name: Bump version
        uses: TriPSs/conventional-changelog-action@v3
        id: version
        with:
          github-token: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
          git-user-name: "GitHub Actions"
          git-user-email: "action@github.com"
          version-file: pyproject.toml
          version-path: project.version
          preset: conventionalcommits
          output-file: false
      - name: Publish to GitHub
        if: steps.version.outputs.skipped == 'false'
        run: gh release create "$TAG" --notes "$BODY"
        env:
          GITHUB_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
          TAG: {% raw %}${{ steps.version.outputs.tag }}{% endraw %}
          BODY: {% raw %}${{ steps.version.outputs.clean_changelog }}{% endraw %}
      {% if not private -%}
      - name: Publish to PyPI
        if: steps.version.outputs.skipped == 'false'
        run: uv build && uv publish
        env:
          UV_PUBLISH_TOKEN: {% raw %}${{ secrets.PYPI_TOKEN }}{% endraw %}
      {% endif -%}
      {% if docker -%}
      - uses: satackey/action-docker-layer-caching@v0.0.11
        if: steps.version.outputs.skipped == 'false'
      - name: Publish to DockerHub
        if: steps.version.outputs.skipped == 'false'
        run: |
          echo "$PASSWORD" | docker login https://ghcr.io -u "$USERNAME" --password-stdin
          docker build -t $REPO:$TAG -t $REPO:latest .
          docker push -a $REPO
        env:
          USERNAME: {% raw %}${{ github.actor }}{% endraw %}
          PASSWORD: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
          REPO: ghcr.io/{% raw %}${{ github.repository }}{% endraw %}
          TAG: {% raw %}${{ steps.version.outputs.tag }}{% endraw %}
      {% endif -%}
